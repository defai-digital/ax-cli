{
  "name": "@defai.digital/ax-monorepo",
  "version": "5.3.6",
  "private": true,
  "sdkVersion": "1.4.0",
  "description": "AX CLI Monorepo - Enterprise-Class AI Coding Assistant CLI ecosystem",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm run build:schemas && pnpm run build:core && pnpm run build:clis",
    "build:schemas": "pnpm --filter @defai.digital/ax-schemas build",
    "build:core": "pnpm --filter @defai.digital/ax-core build",
    "build:clis": "pnpm --filter @defai.digital/ax-grok --filter @defai.digital/ax-cli build",
    "build:grok": "pnpm --filter @defai.digital/ax-grok build",
    "clean": "pnpm -r clean",
    "dev": "tsx packages/ax-grok/src/index.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "ai-coding-assistant",
    "cli",
    "terminal",
    "vibe-coding",
    "glm",
    "grok",
    "xai",
    "z-ai",
    "thinking-mode",
    "vision",
    "web-search",
    "mcp",
    "model-context-protocol",
    "automatosx",
    "ai-agent",
    "multi-provider",
    "code-generation",
    "developer-tools",
    "sdk",
    "programmatic-api"
  ],
  "author": "DEFAI Digital <https://defai.digital>",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@defai.digital/ax-core": "workspace:^",
    "@defai.digital/ax-schemas": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "clipboardy": "^5.0.1",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.0",
    "ink": "^6.5.1",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "node-cache": "^5.1.2",
    "openai": "^6.10.0",
    "react": "^19.2.1",
    "ripgrep-node": "^1.0.0",
    "simple-git": "^3.30.0",
    "tiktoken": "^1.0.21",
    "ts-morph": "^27.0.2",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/fs-extra": "^11.0.2",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/defai-digital/ax-cli.git"
  },
  "bugs": {
    "url": "https://github.com/defai-digital/ax-cli/issues"
  },
  "homepage": "https://github.com/defai-digital/ax-cli#readme",
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "@modelcontextprotocol/sdk": ">=1.25.2"
    }
  }
}
